{
  "schema_version": 1,
  "model_name": "yime_input_candidate_model_v2",
  "purpose": "Classify input materials and govern static retention, dynamic composition, review, and rejection without creating pronunciation or Yinyuan mappings.",
  "safeguards": {
    "source_lexicon_is_read_only": true,
    "proposals_require_review": true,
    "dynamic_composition_requires_approved_components": true,
    "dynamic_composition_uses_only_attested_component_readings": true,
    "llm_must_not_supply_pinyin_or_encoding": true
  },
  "candidate_classes": [
    "single_character",
    "lexical_candidate",
    "fixed_expression",
    "person_name",
    "place_name",
    "organization_name",
    "domain_term",
    "semi_fixed_construction",
    "productive_phrase",
    "syntactic_fragment",
    "noise",
    "context_dependent",
    "unknown"
  ],
  "integration_policies": [
    "static_keep",
    "dynamic_component",
    "dynamic_recoverable",
    "model_only",
    "reject",
    "needs_review"
  ],
  "source_category_hints": {
