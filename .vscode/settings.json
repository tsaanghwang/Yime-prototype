  "wolf.disableHotModeWarning": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "workbench.editorAssociations": {
    "*.db": "sqlite-explorer.option",
    "*.db3": "default",
    "*.sqlite": "default",
    "*.sqlite3": "default",
    "*.sdb": "default",
    "*.s3db": "default",
    "*.copilotmd": "vscode.markdown.preview.editor",
    "*.md": "default",
    "*.mmd": "default",
    "*.tex": "default"
  },
  "editor.fontFamily": "\"Noto Sans\", \"MiSans L3\", \"YinYuan\", \"音元\", Consolas, 'Courier New', monospace",
  "terminal.integrated.fontFamily": "monospace",
  "terminal.integrated.fontLigatures.enabled": true,
  "chat.editor.fontFamily": "\"Noto Sans\", \"MiSans L3\", \"YinYuan Regular\", \"音元 常规\", Consolas, 'Courier New', monospace",
  "editor.inlayHints.fontFamily": "\"Noto Sans\", \"MiSans L3\", \"YinYuan Regular\", \"音元 常规\", Consolas, 'Courier New', monospace",
  "scm.inputFontFamily": "\"Noto Sans\", \"MiSans L3\", \"YinYuan Regular\", \"音元 常规\", Consolas, 'Courier New', monospace",
  "notebook.output.fontFamily": "\"Noto Sans\", \"MiSans L3\", \"YinYuan Regular\", \"音元 常规\", Consolas, 'Courier New', monospace",
  "workbench.list.fontFamily": "\"Noto Sans\", \"MiSans L3\", \"YinYuan Regular\", \"音元 常规\", Consolas, 'Courier New', monospace",
  "sqltools.connections": [
    {
      "name": "Yime Pinyin Hanzi",
      "group": "Yime",
      "driver": "SQLite",
      "database": "${workspaceFolder:Yime}/yime/pinyin_hanzi.db"
    },
    {
      "name": "Source Pinyin",
      "group": "Yime",
      "driver": "SQLite",
      "database": "${workspaceFolder:Yime}/.generated/source_pinyin.db",
      "previewLimit": 100
    }
  ],
  "sqltools.results.customization": {
    "font-family": "\"Noto Sans\", \"MiSans L3\", \"YinYuan Regular\", \"音元 常规\", Consolas, 'Courier New', monospace"
  },
  "pgsql.resultsFontFamily": "\"Noto Sans\", \"MiSans L3\", \"YinYuan Regular\", \"音元 常规\", Consolas, 'Courier New', monospace",
  "latex-workshop.latex.tools": [
    {
      "name": "xelatex",
      "command": "C:\\Program Files\\MiKTeX\\miktex\\bin\\x64\\xelatex.exe",
      "args": ["-synctex=1", "-interaction=nonstopmode", "%DOC%"]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "xelatex",
      "tools": ["xelatex"]
    }
  ],
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "[latex]": {
    "editor.defaultFormatter": "mathematic.vscode-latex"
  },
  "markdown.styles": [".vscode/markdown.css"],
  "markdown.preview.fontFamily": "\"Noto Sans\", \"MiSans L3\", \"YinYuan Regular\", \"Microsoft YaHei\", sans-serif",
  "livePreview.defaultPreviewPath": "/临时.html",
  "files.exclude": {
    "venv_broken_python314": true
  },
  "search.exclude": {
    "venv_broken_python314": true
  },
  "files.watcherExclude": {
    "**/venv_broken_python314/**": true
  },
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
  "python-envs.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
  "sqltools.useNodeRuntime": false,
  "python-envs.defaultPackageManager": "ms-python.python:pip",
  "cursorpyright.analysis.extraPaths": [
    "./tools",
    "./internal_data/hanzi_pinyin"
  ]
}
