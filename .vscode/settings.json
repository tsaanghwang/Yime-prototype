    "*.sqlite3": "sqlite3-editor.editor"
  },
  "sqltools.connections": [
    {
      "name": "Yime Pinyin Hanzi",
      "group": "Yime",
      "driver": "SQLite",
      "database": "${workspaceFolder:Yime}/yime/pinyin_hanzi.db"
    },
    {
      "previewLimit": 50,
      "driver": "SQLite",
      "database": "${workspaceFolder:Yime}/yime.db",
      "name": "Yime"
    },
    {
      "name": "Source Pinyin",
      "group": "Yime",
      "driver": "SQLite",
      "database": "${workspaceFolder:Yime}/internal_data/pinyin_source_db/source_pinyin.db",
      "previewLimit": 100
    }
  ],
  "sqltools.results.customization": {
    "font-family": "\"YinYuan Regular\", \"音元 常规\", \"Noto Sans\", \"Microsoft YaHei\", Consolas, 'Courier New', monospace"
  },
  "pgsql.resultsFontFamily": "\"YinYuan Regular\", \"音元 常规\", \"Noto Sans\", \"Microsoft YaHei\", Consolas, 'Courier New', monospace",
  "latex-workshop.latex.tools": [
    {
      "name": "xelatex",
      "command": "C:\\Program Files\\MiKTeX\\miktex\\bin\\x64\\xelatex.exe",
      "args": ["-synctex=1", "-interaction=nonstopmode", "%DOC%"]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "xelatex",
      "tools": ["xelatex"]
    }
  ],
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "[latex]": {
    "editor.defaultFormatter": "mathematic.vscode-latex"
  },
  "markdown.styles": [".vscode/markdown.css"],
  "markdown.preview.fontFamily": "\"Noto Sans\", \"YinYuan Regular\", \"Microsoft YaHei\", sans-serif",
  "livePreview.defaultPreviewPath": "/临时.html",
  "files.exclude": {
    "venv_broken_python314": true
  },
  "search.exclude": {
    "venv_broken_python314": true
  },
  "files.watcherExclude": {
    "**/venv_broken_python314/**": true
